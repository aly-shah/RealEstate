// Real Estate CRM / ERP — data model
// Multi-tenant: almost every record carries companyId so each business's
// data is fully isolated. See requirements §19.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────── Enums

enum Role {
  SUPER_ADMIN
  OWNER
  ADMIN
  AGENT
  DEALER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

// Subscription tier. Drives the per-tenant limits in lib/plans.ts (user count,
// property count, etc.). PRO is uncapped. Values are deliberately small so
// adding new tiers later doesn't require renaming.
enum CompanyPlan {
  FREE
  TRIAL
  STARTER
  GROWTH
  PRO
}

// Billing lifecycle, independent of CompanyStatus (which gates platform-level
// access). A company can be billingStatus=PAST_DUE while still ACTIVE — the
// app surfaces a warning but keeps working until ops decides to suspend.
enum BillingStatus {
  TRIAL
  ACTIVE
  GRACE
  PAST_DUE
  CANCELLED
}

enum PropertyType {
  // Legacy coarse types (kept so pre-existing listings still load/edit)
  RESIDENTIAL
  COMMERCIAL
  PLOT
  APARTMENT
  // Home
  HOUSE
  FLAT
  UPPER_PORTION
  LOWER_PORTION
  FARM_HOUSE
  ROOM
  PENTHOUSE
  VILLA
  // Plots
  RESIDENTIAL_PLOT
  COMMERCIAL_PLOT
  AGRICULTURAL_LAND
  INDUSTRIAL_LAND
  PLOT_FILE
  PLOT_FORM
  // Commercial
  SHOP
  OFFICE
  WAREHOUSE
  FACTORY
  BUILDING
  OTHER
}

// Area units common in the Pakistan real-estate market. MARLA + KANAL are the
// inherited South-Asian land units (1 marla ≈ 272.25 sqft; 1 kanal = 20 marla).
// The UI is responsible for surface conversion when displaying mixed inventory.
enum AreaUnit {
  SQFT
  SQM
  SQYD
  MARLA
  KANAL
}

enum ListingType {
  SALE
  RENT
  BOTH
}

enum PropertyStatus {
  AVAILABLE
  RESERVED
  UNDER_NEGOTIATION
  RENTED
  SOLD
  INACTIVE
  PENDING_VERIFICATION
}

enum MediaKind {
  PHOTO
  VIDEO
  FLOOR_PLAN
  BROCHURE
}

enum LeadStage {
  NEW
  CONTACTED
  INTERESTED
  SITE_VISIT
  PROPERTY_SHOWN
  NEGOTIATION
  TOKEN_BOOKING
  PAYMENT
  CLOSED_WON
  CLOSED_LOST
}

enum LeadSource {
  REFERRAL
  WALK_IN
  SOCIAL_MEDIA
  PORTAL
  CALL
  REPEAT_CLIENT
  OTHER
}

// Manual hot/warm/cold tag set by an owner/admin to override the computed
// lead score. NULL means "use the auto-computed score" (see lib/lead-score.ts).
enum LeadScoreOverride {
  HOT
  WARM
  COLD
}

// Explicit classification of a Client's side of the market. Previously a Client
// was undifferentiated (role implied only by what it was attached to); this lets
// the CRM segment buyers vs. sellers vs. tenants vs. investors directly. Default
// BUYER so existing rows backfill to the most common case on `prisma db push`.
enum ClientType {
  BUYER
  SELLER
  TENANT
  INVESTOR
}

// How incoming UNASSIGNED leads are auto-assigned (see lib/lead-router.ts).
// MANUAL (default) keeps the existing behaviour — office triages from the leads
// list. ROUND_ROBIN cycles active agents; TERRITORY_MATCH prefers the agent who
// has closed in the lead's area; SHARK_TANK broadcasts to all agents to claim.
enum LeadRoutingStrategy {
  MANUAL
  ROUND_ROBIN
  TERRITORY_MATCH
  SHARK_TANK
}

enum CalendarEventType {
  SHOWING
  MEETING
  FOLLOW_UP
  OPEN_HOUSE
  PAYMENT_REMINDER
  DOCUMENT_REMINDER
  RENTAL_RENEWAL
  DEAL_CLOSING
}

enum CalendarEventStatus {
  SCHEDULED
  DONE
  CANCELLED
  MISSED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  FLAGGED
}

enum InterestLevel {
  HIGH
  MEDIUM
  LOW
  NONE
}

// GpsLog.kind: which side of a visit the location ping captures.
enum GpsLogKind {
  IN
  OUT
}

enum DealType {
  SALE
  RENTAL
}

enum DealStatus {
  DRAFT
  NEGOTIATION
  TOKEN
  BOOKED
  AGREEMENT
  CLOSED_WON
  CLOSED_LOST
}

enum AgreementStatus {
  NONE
  DRAFT
  SIGNED
  COMPLETED
}

// Lifecycle of a rental e-sign / CNIC-verification Contract (model Contract).
// DRAFT → both parties capture their CNIC via the public link → once both are
// recorded it lands in PENDING_VERIFICATION for an office user to finalise →
// ACTIVE → EXPIRED / TERMINATED. The two AWAITING_* states track which party
// the flow is still waiting on.
enum ContractStatus {
  DRAFT
  AWAITING_CNIC_LANDLORD
  AWAITING_CNIC_RENTER
  PENDING_VERIFICATION
  ACTIVE
  EXPIRED
  TERMINATED
}

enum ContractType {
  SALE
  RENTAL
}

enum DealAgentRole {
  MAIN
  CO_AGENT
}

enum PaymentType {
  TOKEN
  BOOKING
  DOWN_PAYMENT
  INSTALMENT
  RENT
  DEPOSIT
  COMMISSION
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

enum CommissionStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PAID
}

enum CommissionParty {
  AGENT_MAIN
  COMPANY
  AGENT_OTHER
  DEALER
}

// Where the "co-agents" slice rolls when there are no co-agents on a deal —
// either back to the main agent (default) or absorbed by the company.
enum FallbackParty {
  MAIN
  COMPANY
}

enum DocumentType {
  CNIC_PASSPORT
  PROPERTY_DOCUMENT
  OWNERSHIP_DOCUMENT
  SALE_AGREEMENT
  RENTAL_AGREEMENT
  PAYMENT_RECEIPT
  DEALER_DOCUMENT
  CLIENT_DOCUMENT
  OTHER
}

enum NotificationType {
  REMINDER
  PAYMENT_DUE
  PAYMENT_OVERDUE
  COMMISSION_APPROVAL
  // Dedicated type so notifications-page filtering can distinguish a
  // rejection from a generic system message.
  COMMISSION_REJECTED
  VISIT_VERIFY
  DOCUMENT_EXPIRY
  LEAD_ASSIGNED
  GENERAL
}

// Channels a notification can be delivered through. Today only IN_APP rows
// are created; the column is here so external-delivery work (Phase 9+) can
// stamp the channel without a follow-on schema migration. The producer of a
// non-IN_APP row would typically *also* still create an IN_APP twin so the
// in-app feed stays canonical.
enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
}

// Background-job lifecycle. The queue is Postgres-backed and walked by a
// cron-driven /api/jobs/tick endpoint — see lib/jobs.ts + deploy/JOBS.md.
enum JobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

// Phase-9 AI features. Each value names one prompt template — keep the list
// narrow; new entries require both a handler under lib/ai/handlers/ and a
// UI surface that triggers it. The body of the suggestion is stored on
// AiSuggestion.content (Markdown-ish); per-month usage is counted by
// scanning AiSuggestion rows so plan-budget enforcement doesn't need a
// separate counter column.
enum AiSuggestionType {
  LEAD_NEXT_ACTION
  LEAD_REPLY_DRAFT
  WHATSAPP_INTENT
  OWNER_WEEKLY_INSIGHT
  // Add-property form: generate a listing title + description from the
  // entered attributes (type, area, rooms, amenities …).
  PROPERTY_COPY
  // Conversation Intelligence: a thread-level brief of a lead's message history
  // (summary, sentiment, objections, commitments, next action).
  LEAD_BRIEF
}

// ─────────────────────────────────────────────────────────── Tenancy & users

model Company {
  id        String        @id @default(cuid())
  name      String
  // URL-friendly identifier. Optional today; reserved for white-label routing
  // (e.g. "clifton-heights.crm.proptimizr.com") in a future phase.
  slug      String?       @unique
  plan      CompanyPlan   @default(STARTER)
  status    CompanyStatus @default(ACTIVE)
  // Per-tenant prefix for auto-generated property references (e.g. "CHR" → CHR-0001).
  // Nullable — when missing, derived from `name` (see lib/refs.ts).
  refPrefix String?

  // White-label / regional fields. All nullable so existing tenants keep
  // working with platform defaults until they actively set them.
  //   - timezone: IANA name (e.g. "Asia/Karachi"). NULL ⇒ server local time.
  //   - brandColor: hex accent ("#4f46e5") for invoice headers + emails.
  //   - logoUrl: URL stored in /uploads or external — replaces the wordmark.
  timezone   String?
  brandColor String?
  logoUrl    String?

  // Phase 8 white-label / billing fields.
  //   - invoiceFooter / receiptFooter: per-tenant override for the footer
  //     text printed on invoice + receipt PDFs.
  //   - whatsappSignature: replaces the default "{agent} — {company}" closer
  //     on WhatsApp templates when set.
  //   - billingStatus: subscription state separate from platform access.
  //   - trialEndsAt / renewalAt: drives the trial-expiry + renewal-due UIs.
  invoiceFooter     String?
  receiptFooter     String?
  whatsappSignature String?
  billingStatus     BillingStatus @default(TRIAL)
  trialEndsAt       DateTime?
  renewalAt         DateTime?

  // Phase-9 master switch. Owner can flip this off to disable every AI
  // surface for the tenant — useful for clients with policy concerns or
  // who simply don't want to pay for the feature even on plans that
  // include it. Defaults true so existing tenants get the feature when
  // their plan grants it. Plan-budget enforcement still runs on top of
  // this flag; see lib/ai/budget.ts.
  aiEnabled Boolean @default(true)

  // Auto-routing strategy for incoming unassigned leads. MANUAL = no auto-route
  // (office triages from the leads list). See lib/lead-router.ts.
  leadRoutingStrategy LeadRoutingStrategy @default(MANUAL)

  // Meta WhatsApp Cloud API `phone_number_id` for this tenant's business
  // line. Used by the inbound webhook to route messages to the correct
  // company — every WA payload carries `metadata.phone_number_id`, we
  // look up the Company here. Unique so two tenants can't claim the
  // same line. NULL until the operator pastes the id in from Business
  // Manager (UI lives on the Settings page).
  whatsappPhoneId String? @unique

  // Meta long-lived access token used for OUTBOUND sends via the
  // Cloud API (lib/wa-business.ts → POST graph.facebook.com).
  // Stored AES-256-GCM-encrypted via lib/crypto.ts (envelope prefix
  // `enc:v1:`); the key is derived from AUTH_SECRET. Settings UI
  // shows a masked placeholder + "Replace" affordance; the cleartext
  // never reaches the client. NULL ⇒ outbound disabled, wa.me links
  // remain the fallback. See deploy/AI.md "At-rest encryption" and
  // deploy/ROTATION.md.
  whatsappAccessToken String?

  // Meta WhatsApp Business Account (WABA) id — the "business" object
  // that owns approved message templates. Distinct from phone_number_id
  // (a WABA can host multiple phone lines). Required for the template
  // catalog sync: GET /v21.0/<wabaId>/message_templates returns the
  // tenant's approved templates which the UI then dropdown-selects.
  // NULL ⇒ template-send dropdown is empty + Settings prompts for it.
  whatsappBusinessAccountId String?

  // soft settings stored as JSON (currency, locale, defaults)
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  properties          Property[]
  projects            Project[]
  unitTypes           UnitType[]
  bookings            Booking[]
  paymentPlans        PaymentPlanTemplate[]
  dealers             Dealer[]
  clients             Client[]
  leads               Lead[]
  calendarEvents      CalendarEvent[]
  showings            Showing[]
  deals               Deal[]
  payments            Payment[]
  invoices            Invoice[]
  commissions         Commission[]
  commissionRules     CommissionRule[]
  documents           Document[]
  activityLogs        ActivityLog[]
  notifications       Notification[]
  aiSuggestions       AiSuggestion[]
  whatsappTemplates   WhatsAppTemplate[]
  whatsappAutomations WhatsAppAutomation[]
  idempotencyKeys     IdempotencyKey[]
  propertyViews       PropertyView[]
  contracts           Contract[]
  dripSequences       DripSequence[]
  dripEnrollments     DripEnrollment[]
}

model User {
  id                 String     @id @default(cuid())
  companyId          String?
  company            Company?   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email              String     @unique
  passwordHash       String
  name               String
  phone              String?
  role               Role
  status             UserStatus @default(ACTIVE)
  avatarUrl          String?
  // private admin remark about an agent + agent's own bio note
  remark             String?
  // Throttled write (~1/min) from requireUser — powers dormant-account
  // detection + "active just now" UI affordances without a separate
  // analytics table. NULL means the user hasn't been seen since this
  // column was added.
  lastSeenAt         DateTime?
  // Round-robin cursor for the lead-routing engine (lib/lead-router.ts). The
  // ROUND_ROBIN strategy assigns the next lead to the active agent with the
  // oldest (or NULL) value here, then stamps it to now() — so assignment cycles
  // evenly. NULL means "never received a routed lead", and sorts first.
  lastLeadAssignedAt DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  dealerProfile     Dealer?           @relation("DealerUser")
  assignedLeads     Lead[]            @relation("LeadAgent")
  propertyLinks     PropertyAgent[]
  calendarEvents    CalendarEvent[]
  showings          Showing[]
  dealLinks         DealAgent[]
  commissionShares  CommissionShare[]
  uploadedDocuments Document[]        @relation("DocUploader")
  verifiedDocuments Document[]        @relation("DocVerifier")
  activityLogs      ActivityLog[]
  notifications     Notification[]
  approvedComms     Commission[]      @relation("CommApprover")

  @@index([companyId])
  // Hot path: every "list this tenant's agents" lookup — 4+ call sites
  // (leads/new, leads/[id], deals/new, calendar). Without this composite
  // PG falls back to the @@index([companyId]) scan + in-memory role filter.
  @@index([companyId, role])
  // Cross-tenant role queries are rare (SUPER_ADMIN console) but kept
  // because the table is small and the write overhead is negligible.
  @@index([role])
}

// ─────────────────────────────────────────────────────────── Inventory

// A builder/developer project (tower, society, mixed development). Its units are
// Property rows linked by projectId; UnitType is the per-layout price list that
// drives bulk unit generation. @default values backfill existing rows so
// `prisma db push` stays non-destructive.
enum ProjectStatus {
  PLANNING
  PRE_LAUNCH
  SELLING
  SOLD_OUT
  COMPLETED
  ON_HOLD
}

model Project {
  id             String         @id @default(cuid())
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  city           String?
  area           String?
  address        String?
  // Map location, captured via the geocoder in the create-project wizard.
  latitude       Float?
  longitude      Float?
  // Building height + how many of the lowest floors are parking (so the
  // apartment floors = parkingFloors+1 … totalFloors).
  totalFloors    Int?
  parkingFloors  Int?
  isOffPlan      Boolean        @default(false)
  status         ProjectStatus  @default(PLANNING)
  // launchDate = construction start; completionDate = expected handover.
  launchDate     DateTime?
  completionDate DateTime?
  // Project-level facilities/amenities (Swimming Pool, Parking, Shops, …).
  amenities      String[]       @default([])
  createdAt      DateTime       @default(now())
  // @default(now()) backfills existing rows on migration; @updatedAt drives future updates.
  updatedAt      DateTime       @default(now()) @updatedAt
  properties     Property[]
  unitTypes      UnitType[]
  media          ProjectMedia[]

  @@index([companyId])
}

// Project-level media — renderings, master/floor plans, brochures. Mirrors
// PropertyMedia but for the whole development; cascades with the project (and so
// with the tenant). companyId is a scalar for query scoping.
model ProjectMedia {
  id        String    @id @default(cuid())
  companyId String
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kind      MediaKind @default(PHOTO)
  url       String
  caption   String?
  createdAt DateTime  @default(now())

  @@index([projectId])
}

// Per-project unit layout + price list (e.g. "2-Bed", basePrice + floorRise).
// Buyers/dealers see the "from" price; the generator computes each unit's price
// as basePrice + (floorNumber - 1) * floorRise.
model UnitType {
  id            String     @id @default(cuid())
  companyId     String
  company       Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  bedrooms      Int?
  bathrooms     Int?
  areaValue     Float?
  areaUnit      AreaUnit   @default(SQFT)
  basePrice     Decimal    @db.Decimal(14, 2)
  // Amount added per floor above this type's lowest floor (floor-rise pricing).
  floorRise     Decimal    @default(0) @db.Decimal(14, 2)
  // Placement within the building — which tower/floors this layout occupies and
  // how many sit on each of those floors. Drives unit generation.
  tower         String?
  floorFrom     Int?
  floorTo       Int?
  unitsPerFloor Int?
  createdAt     DateTime   @default(now())
  properties    Property[]

  @@index([companyId])
  @@index([projectId])
}

model Dealer {
  id              String     @id @default(cuid())
  companyId       String
  company         Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId          String?    @unique
  user            User?      @relation("DealerUser", fields: [userId], references: [id])
  name            String
  contact         String?
  companyName     String?
  areaOfOperation String?
  status          UserStatus @default(ACTIVE)
  // dealer's agreed default share % on deals from their inventory
  defaultSharePct Decimal    @default(0) @db.Decimal(5, 2)
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @default(now()) @updatedAt

  properties       Property[]
  deals            Deal[]
  documents        Document[]
  // Historical commission shares paid out to this dealer. Modeled (vs. raw
  // dealerId String) so deleting a dealer set-nulls the share rather than
  // erroring out, and ad-hoc queries can join via the relation.
  commissionShares CommissionShare[]

  @@index([companyId])
}

model Property {
  id          String         @id @default(cuid())
  companyId   String
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reference   String
  title       String
  description String?
  type        PropertyType
  listingType ListingType    @default(SALE)
  status      PropertyStatus @default(PENDING_VERIFICATION)

  projectId String?
  // SetNull: deleting a project shouldn't error out properties belonging to it.
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Tower-unit placement within a project (builder inventory). `floorNumber` is
  // the unit's floor — distinct from `floors` below (the building's height).
  unitTypeId  String?
  unitType    UnitType? @relation(fields: [unitTypeId], references: [id], onDelete: SetNull)
  tower       String?
  floorNumber Int?
  unitNumber  String?

  // supplier: either a dealer or a private owner captured inline
  dealerId   String?
  // SetNull: deleting a dealer orphans (but preserves) the property; ownerName
  // fallback covers the supplier-side displayed in the UI.
  dealer     Dealer? @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  ownerName  String?
  ownerPhone String?

  // location
  city      String?
  area      String?
  address   String?
  latitude  Float?
  longitude Float?
  landmarks String?

  // pricing
  salePrice   Decimal? @db.Decimal(14, 2)
  monthlyRent Decimal? @db.Decimal(14, 2)
  deposit     Decimal? @db.Decimal(14, 2)
  negotiable  Boolean  @default(true)

  // size & layout
  coveredArea Float?
  plotSize    Float?
  // Defaults to SQFT (covers >90% of urban Karachi inventory); switch per
  // listing for plots / villas typically measured in MARLA / KANAL.
  areaUnit    AreaUnit? @default(SQFT)
  bedrooms    Int?
  bathrooms   Int?
  floors      Int?
  parking     Int?
  yearBuilt   Int?
  // Curated amenity tags (Parking, Lift, Backup generator, …) chosen from the
  // chip picker in the Add-property form. Postgres text[]; empty default so
  // existing rows backfill cleanly and `prisma db push` stays non-destructive.
  amenities   String[]  @default([])

  // availability
  availableFrom DateTime?
  rentedUntil   DateTime?

  // commission override
  commissionRuleId String?
  // SetNull: deleting a rule falls the property back to the company default.
  commissionRule   CommissionRule? @relation(fields: [commissionRuleId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Optimistic-lock counter. The edit form round-trips this; casUpdateGuarded
  // only writes when it still matches, then bumps it — so two agents editing
  // the same listing can't silently clobber each other. @default(0) backfills
  // existing rows cleanly (non-destructive db push).
  version Int @default(0)

  // Public client-facing share link (served at /p/[shareSlug]). shareSlug is an
  // unguessable random token, NOT the id, so a client holding one link can't
  // enumerate other listings. shareEnabled lets the agent revoke access without
  // losing the URL; sharedById is the agent shown to the client as the contact.
  shareSlug    String? @unique
  shareEnabled Boolean @default(true)
  sharedById   String?

  media     PropertyMedia[]
  agents    PropertyAgent[]
  leads     Lead[]
  showings  Showing[]
  deals     Deal[]
  documents Document[]
  events    CalendarEvent[]
  views     PropertyView[]
  bookings  Booking[]

  @@unique([companyId, reference])
  @@index([companyId])
  // Composite — used by every filtered list query (status filter + tenant scope).
  // The pre-refinement @@index([status]) only served cross-tenant queries
  // the codebase doesn't make; dropped to reduce write overhead.
  @@index([companyId, status])
  // Dealer-scoped property lists (the DEALER role's propertyScope filters by
  // dealerId) + an efficient SetNull when a dealer is deleted.
  @@index([dealerId])
  // Phase 5 added a city filter on /properties — case-insensitive exact match
  // benefits from an index on the raw column (Postgres still seq-scans for
  // ILIKE but the equality lookup hits this).
  @@index([companyId, city])
}

// Channel-sales booking: a dealer (or agent) reserves a unit for a buyer; the
// builder/office approves or rejects. Approval marks the unit SOLD; rejection
// releases it back to AVAILABLE. Kept separate from Deal so the dealer-initiated
// request and the builder's approval are an explicit, auditable step. dealerId /
// clientId / bookedById are scalar FKs (no relation) — booking is a transient
// workflow record; the company + property relations carry the tenant cascade.
enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Booking {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  propertyId    String
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  dealerId      String?
  clientId      String?
  // Buyer captured inline when there's no Client record yet.
  clientName    String?
  clientPhone   String?
  bookedById    String?
  status        BookingStatus @default(PENDING)
  // Agreed sale price (may differ from the unit's list price after a discount).
  price         Decimal       @db.Decimal(14, 2)
  discount      Decimal?      @db.Decimal(14, 2)
  notes         String?
  // Optional installment plan applied to the schedule when approved.
  paymentPlanId String?
  // The Deal created on approval (revenue record the payment schedule hangs off).
  dealId        String?
  reviewedById  String?
  reviewedAt    DateTime?
  reviewNote    String?
  // Optimistic-lock counter so two approvers can't both action one booking.
  version       Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt

  @@index([companyId, status])
  @@index([propertyId])
  @@index([dealerId])
}

// Reusable installment plan (e.g. "10% booking, 10% confirmation, 80% over 36
// months"). Applied to a booking on approval to auto-generate the Payment
// schedule against the created Deal.
model PaymentPlanTemplate {
  id          String             @id @default(cuid())
  companyId   String
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime           @default(now())
  milestones  PaymentMilestone[]

  @@index([companyId])
}

model PaymentMilestone {
  id             String              @id @default(cuid())
  templateId     String
  template       PaymentPlanTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  order          Int                 @default(0)
  label          String
  // Total % of the sale price this milestone covers (split across `count`).
  pct            Decimal             @db.Decimal(6, 3)
  type           PaymentType         @default(INSTALMENT)
  // Number of payments this milestone expands into (e.g. 36 monthly installments).
  count          Int                 @default(1)
  // Months from approval to the first payment, and the spacing between them.
  firstDueMonths Int                 @default(0)
  intervalMonths Int                 @default(1)

  @@index([templateId])
}

model PropertyMedia {
  id         String    @id @default(cuid())
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  kind       MediaKind @default(PHOTO)
  url        String
  caption    String?
  createdAt  DateTime  @default(now())

  @@index([propertyId])
}

model PropertyAgent {
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agentId    String
  agent      User     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([propertyId, agentId])
  @@index([agentId])
}

// ─────────────────────────────────────────────────────────── CRM

model Client {
  id              String     @id @default(cuid())
  companyId       String
  company         Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name            String
  phone           String?
  email           String?
  address         String?
  // Which side of the market this contact represents. Drives CRM segmentation
  // and (future) type-aware matching. Defaults BUYER (the most common case).
  type            ClientType @default(BUYER)
  // Marketing/automation opt-out (DNC). When true, MARKETING automation — drip
  // sequences, promotional templates — skips this contact. Transactional sends
  // (contract verification, receipts) are operational and not gated by this.
  // Default false = consented; proper opt-IN capture is a later hardening.
  marketingOptOut Boolean    @default(false)
  // Audit: when the opt-out was set and where it came from
  // ("WhatsApp STOP" | "manual" | "import"). Cleared on re-subscribe.
  optOutAt        DateTime?
  optOutSource    String?
  // Login-free client portal (served at /portal/[portalToken]). portalToken is
  // an unguessable random token, NOT the id; portalEnabled lets the agent revoke
  // access without losing the URL. Mirrors Property.shareSlug.
  portalToken     String?    @unique
  portalEnabled   Boolean    @default(false)
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @default(now()) @updatedAt

  leads           Lead[]
  showings        Showing[]
  deals           Deal[]
  invoices        Invoice[]
  documents       Document[]
  propertyViews   PropertyView[]
  rentalContracts Contract[]

  @@index([companyId])
  // Speeds up the de-dup lookup in createLead (phone / email match within a tenant).
  @@index([companyId, phone])
  @@index([companyId, email])
}

model Lead {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId   String?
  // SetNull: client deletion shouldn't cascade-destroy historical leads; the
  // lead's stage + lostReason carry the business meaning even if client is gone.
  client     Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  agentId    String?
  // SetNull: deleting an agent un-assigns their leads (admins can reassign).
  agent      User?     @relation("LeadAgent", fields: [agentId], references: [id], onDelete: SetNull)
  propertyId String?
  // SetNull: deleting a property unlinks the lead but the enquiry stays.
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  stage  LeadStage  @default(NEW)
  source LeadSource @default(OTHER)

  // client preferences
  budgetMin    Decimal?      @db.Decimal(14, 2)
  budgetMax    Decimal?      @db.Decimal(14, 2)
  prefType     PropertyType?
  prefArea     String?
  requirements String?

  notes           String?
  lostReason      String?
  // Admin-set hot/warm/cold tag that overrides the computed score when present.
  scoreOverride   LeadScoreOverride?
  // Free-text portal tag set by CSV/portal imports — "ZAMEEN", "GRAANA",
  // "OLX", "FACEBOOK", "CSV". Kept as a string (not an enum) so the operator
  // can add new portals without a schema migration.
  importSource    String?
  // Explicit signal of when this lead was last meaningfully contacted —
  // updated by recordShowing + by marking a SHOWING/MEETING/FOLLOW_UP
  // calendar event DONE. Replaces `updatedAt` as the freshness proxy for
  // stale-lead detection so editing notes or assigning an agent doesn't
  // falsely "refresh" the lead. NULL falls back to createdAt at the
  // computation layer (see lib/lead-health.ts).
  lastContactedAt DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  events          CalendarEvent[]
  deals           Deal[]
  showings        Showing[]
  dripEnrollments DripEnrollment[]

  @@index([companyId])
  @@index([agentId])
  // Agent-filtered leads list: equality on (companyId, agentId) + ordering by
  // updatedAt is a single index seek at any keyset depth — also serves the
  // "unassigned" bucket (agentId IS NULL) the same way.
  @@index([companyId, agentId, updatedAt])
  // Funnel + recency: every leads-list query orders by updatedAt within scope.
  // The leading `companyId` column also satisfies the rare stage-only filter
  // when combined with the tenant gate — the bare @@index([stage]) it
  // replaced only served cross-tenant queries the codebase doesn't make.
  @@index([companyId, stage, updatedAt])
  // "Leads interested in property X" — used on the property detail page.
  @@index([propertyId])
  // "Leads for client X" — for the client-dedup activity trail.
  @@index([clientId])
  // Phase 5: portal-source reporting ("how many leads from Zameen this month").
  @@index([companyId, importSource])
  // Phase 7 reports filter by createdAt range (leadSourceConversion,
  // funnelDropoff) — without this index every report-page render scans the
  // full lead table per tenant.
  @@index([companyId, createdAt])
}

model CalendarEvent {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agentId    String?
  // SetNull on all three optional FKs so deleting an agent/lead/property
  // unlinks but preserves the historical schedule.
  agent      User?     @relation(fields: [agentId], references: [id], onDelete: SetNull)
  leadId     String?
  lead       Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  type      CalendarEventType
  status    CalendarEventStatus @default(SCHEDULED)
  title     String
  notes     String?
  startAt   DateTime
  endAt     DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @default(now()) @updatedAt

  @@index([companyId])
  @@index([agentId])
  @@index([startAt])
  // "Today's schedule" for a tenant — narrows by company + day range.
  @@index([companyId, startAt])
  // Events from a specific lead (lead detail page sidebar).
  @@index([leadId])
}

model Showing {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agentId    String
  // Agent + property are required FKs; the deal-style historical record
  // demands their presence, so a delete is intentionally blocked here.
  agent      User     @relation(fields: [agentId], references: [id])
  clientId   String?
  // SetNull: client deletion shouldn't erase the showing record.
  client     Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  // Optional link back to the lead that triggered the visit. Multiple
  // pages (leads list, lead detail, AI assistant) need "showings for
  // this lead" without conflating it with "showings for this client" —
  // one client may have several active leads on different properties.
  // SetNull so deleting a lead doesn't orphan the historical visit.
  leadId     String?
  lead       Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])

  checkInAt      DateTime?
  checkOutAt     DateTime?
  checkInLat     Float?
  checkInLng     Float?
  manualLocation String?
  notes          String?
  clientFeedback String?
  interestLevel  InterestLevel?
  verification   VerificationStatus @default(PENDING)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @default(now()) @updatedAt

  gpsLogs GpsLog[]

  @@index([companyId])
  @@index([agentId])
  // "Visits to verify" admin queue + "active days" per agent both filter by
  // tenant + checkInAt within a recent window.
  @@index([companyId, checkInAt])
  // Property detail page lists showings for a property.
  @@index([propertyId])
  // Lead detail page + AI handlers list showings for a lead.
  @@index([leadId])
  // Phase 7: visit-verification-rate report buckets by createdAt — including
  // attempted visits that never reached a checkIn.
  @@index([companyId, createdAt])
  // Client portal lists a client's visits (WHERE clientId) + the portal media
  // gate; also serves the SetNull when a client is deleted. Mirrors Lead.clientId.
  @@index([clientId])
}

model GpsLog {
  id         String     @id @default(cuid())
  showingId  String
  showing    Showing    @relation(fields: [showingId], references: [id], onDelete: Cascade)
  kind       GpsLogKind
  latitude   Float
  longitude  Float
  capturedAt DateTime   @default(now())

  @@index([showingId])
}

// ─────────────────────────────────────────────────────────── Deals & money

model Deal {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reference String

  type      DealType
  status    DealStatus      @default(DRAFT)
  agreement AgreementStatus @default(NONE)

  propertyId String
  // Property is required for a deal; deletion is intentionally blocked here.
  property   Property @relation(fields: [propertyId], references: [id])
  clientId   String?
  // All three optional FKs SetNull: deals are the immutable revenue record
  // and must survive the deletion of their counterparties.
  client     Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  dealerId   String?
  dealer     Dealer?  @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  leadId     String?
  lead       Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  closeDate                 DateTime?
  // Forward-looking close estimate for pipeline forecasting. Distinct from
  // closeDate, which is stamped only when the deal actually reaches CLOSED_WON.
  estimatedCloseDate        DateTime?
  // Gross commission as a percentage of the deal value (the GCI% input).
  // Captured at the deal level so reporting can compute Gross Commission Income
  // directly without re-deriving it from the commission split. Decimal(5,2);
  // 0 until set, which backfills existing rows cleanly on `prisma db push`.
  grossCommissionPercentage Decimal   @default(0) @db.Decimal(5, 2)
  // Populated when status transitions to CLOSED_LOST (required at UI + action).
  lostReason                String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  agents     DealAgent[]
  sale       Sale?
  rental     Rental?
  payments   Payment[]
  invoices   Invoice[]
  commission Commission?
  documents  Document[]
  contract   Contract?
  checklist  DealChecklistItem[]

  @@unique([companyId, reference])
  @@index([companyId])
  // Revenue trend + month KPIs filter by companyId + status + closeDate.
  // The pre-refinement bare @@index([status]) was cross-tenant; dropped.
  @@index([companyId, closeDate])
  // Deals derived from a specific lead (lead detail page sidebar).
  @@index([leadId])
  @@index([dealerId])
  // Property detail page lists a listing's deals (`include: { deals: true }`).
  // propertyId is a required FK, so without this every property-detail view
  // full-scans the Deal table. Mirrors Lead/Showing/Document.propertyId.
  @@index([propertyId])
  // Client portal lists a client's deals + payments (WHERE clientId); also
  // serves the SetNull when a client is deleted. Mirrors Lead.clientId.
  @@index([clientId])
}

model DealAgent {
  dealId  String
  deal    Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  agentId String
  agent   User          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  role    DealAgentRole @default(CO_AGENT)

  @@id([dealId, agentId])
  @@index([agentId])
}

// Per-deal closing checklist — required documents/milestones that must be
// completed before the deal can be marked CLOSED_WON (the compliance gate in
// setDealStatus). Seeded with a default set per deal type on creation; the
// office can add/remove items. Items are checked off manually for v1 (linking
// each to a verified Document is a later enhancement).
model DealChecklistItem {
  id        String    @id @default(cuid())
  dealId    String
  deal      Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  label     String
  required  Boolean   @default(true)
  done      Boolean   @default(false)
  doneAt    DateTime?
  order     Int       @default(0)
  createdAt DateTime  @default(now())

  // Deal detail page lists items by dealId; also serves the deal-delete cascade.
  @@index([dealId])
}

model Sale {
  id            String   @id @default(cuid())
  dealId        String   @unique
  deal          Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  salePrice     Decimal  @db.Decimal(14, 2)
  tokenAmount   Decimal? @db.Decimal(14, 2)
  bookingAmount Decimal? @db.Decimal(14, 2)
  downPayment   Decimal? @db.Decimal(14, 2)
}

model Rental {
  id          String    @id @default(cuid())
  dealId      String    @unique
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  monthlyRent Decimal   @db.Decimal(14, 2)
  deposit     Decimal?  @db.Decimal(14, 2)
  leaseMonths Int?
  renewalDate DateTime?
}

// Rental e-sign / CNIC-verification contract. One per rental Deal (dealId is
// unique). Terms are a frozen snapshot of the Rental at creation time so later
// edits to the deal don't rewrite a legally-meaningful record. Each party gets
// an unguessable token that backs a public verify link sent over WhatsApp; the
// link lets them photograph their CNIC, which is OCR'd and recorded here.
//
// Note vs. the pasted spec: landlordId/renterId are nullable plain identifiers
// (the renter's Client id, the landlord's phone) — NOT foreign keys — because a
// landlord is a property owner who may have no Client/User row. The Document
// written on verification links by dealId (always valid) and only sets clientId
// for the renter when it's a real Client. CNIC numbers are stored as captured;
// at-rest encryption (lib/crypto.ts) is a sensible future hardening.
model Contract {
  id        String         @id @default(cuid())
  companyId String
  dealId    String         @unique // Ties directly to a Deal (sale or rental).
  status    ContractStatus @default(DRAFT)
  // RENTAL snapshots the lease terms; SALE snapshots salePrice. The landlord/
  // renter columns below double as seller/buyer for a SALE — the two-party CNIC
  // e-sign flow is identical, so one model serves both deal types.
  type      ContractType   @default(RENTAL)

  // Terms mirrored from the deal for legal-snapshot stability — only the block
  // matching `type` is populated; the other stays null.
  monthlyRent Decimal?  @db.Decimal(14, 2) // RENTAL
  deposit     Decimal?  @db.Decimal(14, 2) // RENTAL
  leaseMonths Int? // RENTAL
  startDate   DateTime? // RENTAL
  endDate     DateTime? // RENTAL
  salePrice   Decimal?  @db.Decimal(14, 2) // SALE
  tokenAmount Decimal?  @db.Decimal(14, 2) // SALE — token / bayana paid
  downPayment Decimal?  @db.Decimal(14, 2) // SALE — down payment

  // Operator-editable agreement fields (both types). possessionDate drives the
  // handover note; customClauses are free-text special terms appended to the
  // generated agreement.
  possessionDate    DateTime?
  customClauses     String?
  // Per-document free-text overrides, keyed by document kind:
  //   { "<kind>": { "mode": "append" | "replace", "text": "..." } }
  // Lets an operator append to — or fully replace — any generated document's
  // body before printing, without leaving the template for the rest.
  documentOverrides Json?

  // Party A verification — "landlord" for RENTAL, "seller" for SALE. landlordId
  // holds the best-available identifier (the property's ownerPhone) — not an FK.
  landlordId         String?
  landlordCnic       String? // Extracted via OCR.
  landlordCnicName   String? // Extracted via OCR.
  landlordVerifiedAt DateTime?
  landlordToken      String    @unique @default(cuid()) // Public access-link token.

  // Party B verification — "renter" for RENTAL, "buyer" for SALE. renterId is
  // that party's Client id (FK `renter`).
  renterId         String?
  renterCnic       String? // Extracted via OCR.
  renterCnicName   String? // Extracted via OCR.
  renterVerifiedAt DateTime?
  renterToken      String    @unique @default(cuid()) // Public access-link token.

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  // The renter is a real Client (the landlord is a property owner with no Client
  // row, so landlordId stays a plain identifier). SetNull preserves the
  // historical contract if the client is deleted.
  renter  Client? @relation(fields: [renterId], references: [id], onDelete: SetNull)

  // dealId / landlordToken / renterToken are already indexed by their @unique
  // constraints, so the token + deal lookups need no extra index.
  @@index([companyId])
  // "Contracts to finalise" office queue (status = PENDING_VERIFICATION) +
  // tenant-scoped list — mirrors the [companyId, status] index every other
  // status-bearing model carries.
  @@index([companyId, status])
  // Efficient SetNull when a renter Client is deleted.
  @@index([renterId])
}

model Payment {
  id             String        @id @default(cuid())
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  dealId         String?
  // SetNull: a payment record is preserved (for accounting) even if its deal
  // is removed. Reconciliation falls back to the in-row metadata.
  deal           Deal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)
  invoiceId      String?
  // SetNull: same reasoning as deal — the payment row is the source of truth
  // for "money received"; invoice gone shouldn't drop the receipt.
  invoice        Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  type           PaymentType
  amount         Decimal       @db.Decimal(14, 2)
  status         PaymentStatus @default(PENDING)
  // Optimistic-lock counter (PR4) — bumped on every guarded write so a stale
  // editor's compare-and-swap matches no rows instead of overwriting newer data.
  version        Int           @default(0)
  method         String?
  receiptNo      String?
  dueDate        DateTime?
  paidAt         DateTime?
  notes          String?
  // Last time a due/overdue reminder was sent — gates the payment-reminder
  // sweep (lib/jobs/sweeps.ts) so it doesn't re-notify the same payment daily.
  lastReminderAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt

  @@index([companyId])
  // Outstanding-payments aggregates (lib/metrics.ts) filter by companyId +
  // status (PENDING/PARTIAL/OVERDUE): the count and both money sums hit this
  // composite instead of scanning every payment in the tenant. Added with the
  // PR1 rewrite from row-fetch+JS-reduce to SQL aggregate. A bare @@index([status])
  // is still avoided — it would only serve cross-tenant queries we never make.
  @@index([companyId, status])
  // Overdue scan: companyId + dueDate (+ status filter applied by query).
  @@index([companyId, dueDate])
  // Per-deal payment history pulls by dealId; with most deals having ≤10
  // payments, the index keeps the join fast at scale.
  @@index([dealId])
  // Per-invoice payment sum — drives auto-promotion of Invoice.status when
  // payments cover the issued amount.
  @@index([invoiceId])
}

model Invoice {
  id          String        @id @default(cuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  dealId      String?
  // SetNull: invoices outlive their underlying deal record for audit.
  deal        Deal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  number      String
  amount      Decimal       @db.Decimal(14, 2)
  status      InvoiceStatus @default(ISSUED)
  // Optional free-text invoice-line description ("Booking instalment 2/4").
  description String?
  // Optional footer for printed invoices ("Thank you for your business.")
  // — overrides the per-company default when set.
  footer      String?
  issuedAt    DateTime      @default(now())
  dueDate     DateTime?
  updatedAt   DateTime      @default(now()) @updatedAt

  payments Payment[]

  // Prevent duplicate invoice numbers within a tenant. NOTE: safe to add only
  // when no UI creates invoices yet (Phase 3 work); if you've back-loaded
  // invoices manually, run dedupe SQL before `prisma db push`.
  @@unique([companyId, number])
  @@index([companyId])
  // List page filters by status; index supports the "draft/issued/paid/overdue"
  // tabs without sequential scan.
  @@index([companyId, status])
  // Deal detail page lists a deal's invoices (`include: { invoices: true }` →
  // Invoice WHERE dealId). Without this every deal-detail view scans the Invoice
  // table; also keeps the SetNull cheap when a deal is deleted. Mirrors
  // Payment.dealId / Document.dealId.
  @@index([dealId])
}

model CommissionRule {
  id              String        @id @default(cuid())
  companyId       String
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name            String
  isDefault       Boolean       @default(false)
  mainAgentPct    Decimal       @default(50) @db.Decimal(5, 2)
  companyPct      Decimal       @default(25) @db.Decimal(5, 2)
  otherAgentPct   Decimal       @default(25) @db.Decimal(5, 2)
  dealerPct       Decimal       @default(0) @db.Decimal(5, 2)
  // Where the "co-agents" portion goes when no co-agents are on the deal.
  noOtherFallback FallbackParty @default(MAIN)
  createdAt       DateTime      @default(now())

  properties Property[]

  @@index([companyId])
}

model Commission {
  id           String           @id @default(cuid())
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  dealId       String           @unique
  deal         Deal             @relation(fields: [dealId], references: [id], onDelete: Cascade)
  totalAmount  Decimal          @db.Decimal(14, 2)
  status       CommissionStatus @default(DRAFT)
  // Optimistic-lock counter (PR4). See Payment.version.
  version      Int              @default(0)
  approvedById String?
  // SetNull: a deleted approver shouldn't drop the historical commission row.
  approvedBy   User?            @relation("CommApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime?
  // Optional context captured at approval time ("Approved with reduced co-agent share").
  // Rejection deletes the commission entirely; the reason is captured in
  // ActivityLog meta and queryable from there, so no rejectionReason column.
  approvalNote String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @default(now()) @updatedAt

  shares CommissionShare[]

  @@index([companyId])
  // Approval queue + commission totals widget filter by tenant + status.
  @@index([companyId, status])
}

model CommissionShare {
  id           String          @id @default(cuid())
  commissionId String
  commission   Commission      @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  party        CommissionParty
  userId       String?
  // SetNull: deleted agents lose the linkage but the historical amount/label
  // remain — important for audit and for "Company" / "Dealer" parties anyway.
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  dealerId     String?
  // Now a proper FK (was a bare String). SetNull mirrors the user-side.
  dealer       Dealer?         @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  label        String
  pct          Decimal         @db.Decimal(5, 2)
  amount       Decimal         @db.Decimal(14, 2)
  paid         Boolean         @default(false)
  paidAt       DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @default(now()) @updatedAt

  @@index([commissionId])
  // Per-agent earnings (agent profile + agent dashboard "pending/earned").
  @@index([userId])
  // Per-dealer earnings (dealer dashboard + dealer detail page).
  @@index([dealerId])
}

// ─────────────────────────────────────────────────────────── Documents & system

model Document {
  id        String       @id @default(cuid())
  companyId String
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type      DocumentType
  name      String
  url       String
  version   Int          @default(1)

  verification VerificationStatus @default(PENDING)
  verifiedById String?
  // SetNull: deleted verifier shouldn't cascade-drop the verification record.
  verifiedBy   User?              @relation("DocVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
  expiryDate   DateTime?

  uploadedById String?
  uploadedBy   User?   @relation("DocUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  // polymorphic-ish links — each SetNull so the document survives when the
  // linked subject is removed (document is a fact in its own right).
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  clientId   String?
  client     Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  dealerId   String?
  dealer     Dealer?   @relation(fields: [dealerId], references: [id], onDelete: SetNull)
  dealId     String?
  deal       Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([companyId])
  // "Docs to check" admin KPI + the documents page status filter.
  @@index([companyId, verification])
  // "Expiring soon" / "Expired" badges scan by tenant + expiryDate. The
  // pre-refinement standalone @@index([expiryDate]) was cross-tenant and
  // never picked — every document query filters by companyId first.
  @@index([companyId, expiryDate])
  // Documents list page orders by createdAt desc within tenant.
  @@index([companyId, createdAt])
  // Detail pages list docs by their subject FK (deal/[id], dealer/[id],
  // property/[id] all `include: { documents: true }`). Each index makes that
  // lookup a seek instead of a tenant-wide scan, and keeps the SetNull cheap
  // when the subject is deleted. clientId is intentionally left unindexed — no
  // page lists documents by client, so it'd only serve the rare client-delete.
  @@index([propertyId])
  @@index([dealId])
  @@index([dealerId])
}

model ActivityLog {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId     String?
  // SetNull: an audit log is preserved as "System" if the actor is deleted.
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  summary    String
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([companyId])
  // Entity-scoped timeline (lead/property detail pages). Composite is fully
  // tenant-scoped + naturally sorted, so the lead-detail query
  //   WHERE companyId AND entityType='LEAD' AND entityId=X ORDER BY createdAt DESC
  // hits a single index range scan instead of cross-tenant entity lookup
  // + sort. Replaces the pre-refinement @@index([entityType, entityId]).
  @@index([companyId, entityType, entityId, createdAt])
  // /activity page + 30-day metrics order by tenant + createdAt desc.
  @@index([companyId, createdAt])
  // Per-user activity (agent profile timeline + /activity ?user= filter).
  @@index([userId])
}

model Notification {
  id        String              @id @default(cuid())
  companyId String
  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType    @default(GENERAL)
  // Delivery channel — defaults IN_APP. External-delivery integrations
  // (Phase 9+) populate non-IN_APP rows; the in-app feed query filters to
  // IN_APP so it doesn't show "sent SMS" entries as if they were unread alerts.
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String?
  link      String?
  read      Boolean             @default(false)
  createdAt DateTime            @default(now())

  @@index([userId, read])
  // /notifications orders by createdAt desc; pairs with the (userId, read) one
  // which serves the topbar/sidebar unread-count badge.
  @@index([userId, createdAt])
}

// Phase-8.5 background-job queue. Intentionally minimal — no Redis, no
// external workers; a cron-driven /api/jobs/tick endpoint reads QUEUED rows
// with runAt<=now, dispatches via lib/jobs.ts handlers, and writes back
// DONE/FAILED. Good enough for trial-expiry sweeps, WhatsApp inbound
// processing, and the small batches AI features will need.
//
// companyId is nullable: platform-level jobs (e.g. cross-tenant trial sweep)
// pass null; tenant-scoped jobs (per-company AI runs) set it.
/// Durable last-run marker for the daily-throttled cron sweeps (purge, payment
/// reminders, WhatsApp token/catalog). Replaces per-process globals so a PM2
/// restart / deploy no longer re-fires a daily sweep within its 24h window.
model SweepState {
  key       String   @id // e.g. "payment-reminders", "purge"
  lastRunAt DateTime
  updatedAt DateTime @default(now()) @updatedAt
}

/// AI Copilot conversation insight — one row per (company, phone), refreshed on
/// each inbound WhatsApp message. Drives the inbox intent/urgency/sentiment
/// badges + suggested action. Tenant-scoped via companyId.
model WhatsAppConversationInsight {
  id              String   @id @default(cuid())
  companyId       String
  leadId          String?
  clientId        String?
  phone           String
  intent          String // NEW_BUYER, NEW_RENTAL, BUDGET, LOCATION, VISIT, NEGOTIATION, DOC_PAYMENT, COMPLAINT, FOLLOW_UP, NOT_INTERESTED, SPAM
  urgency         String // LOW, MEDIUM, HIGH
  sentiment       String // POSITIVE, NEUTRAL, NEGATIVE
  summary         String?
  suggestedAction String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  // One insight per conversation (company + phone) — upserted each inbound.
  @@unique([companyId, phone])
  @@index([companyId, leadId])
}

/// QR-linked (unofficial / Baileys) WhatsApp session status per company. The
/// actual auth credentials live on disk (per-company session dir); this row only
/// tracks linking status for the UI.
model WhatsAppSession {
  companyId String    @id
  status    String    @default("DISCONNECTED") // PENDING | CONNECTED | DISCONNECTED
  phone     String? // linked number (jid) once connected
  linkedAt  DateTime?
  updatedAt DateTime  @default(now()) @updatedAt
}

model Job {
  id             String    @id @default(cuid())
  companyId      String?
  type           String
  payload        Json?
  status         JobStatus @default(QUEUED)
  runAt          DateTime  @default(now())
  attempts       Int       @default(0)
  maxAttempts    Int       @default(3)
  result         Json?
  error          String?
  // Set when the runner flips the row to RUNNING. Distinct from startedAt
  // so the reaper sweep can detect "RUNNING but never finished" rows
  // (server crashed mid-job) and reset them back to QUEUED.
  claimedAt      DateTime?
  startedAt      DateTime?
  finishedAt     DateTime?
  // Producer-supplied dedup key. Combined with `type` in a unique index so
  // a webhook retry (Meta retries on timeout) doesn't enqueue the same
  // message twice — enqueueJob catches P2002 and returns the original id.
  // NULL is allowed and repeats freely (multi-NULL is fine in Postgres).
  idempotencyKey String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  // Webhook retry dedup. Type-scoped so different job types can reuse keys
  // (e.g. a message id might be unique within whatsapp.inbound but collide
  // with an unrelated payload id in some other type).
  @@unique([type, idempotencyKey])
  // Hot path: the tick endpoint scans QUEUED + due rows.
  @@index([status, runAt])
  // Admin view filters by status (FAILED first) — fast even at scale.
  @@index([status, createdAt])
  // Retention purge scans DONE rows older than the TTL — separate index so
  // the cleanup query doesn't fight the admin-view index.
  @@index([status, finishedAt])
  // Tenant-scoped queries (per-company job history).
  @@index([companyId])
  @@index([type])
}

// Phase-9 AI output cache + audit trail. One row per Claude call —
// repeated clicks within the cache window (~30 min) return the existing
// suggestion instead of re-hitting the API. Doubles as the data source
// for monthly per-tenant budget enforcement (lib/ai/budget.ts) and the
// transparency surface "AI was used N times this month" on Settings.
//
// Polymorphic entity link: entityType + entityId point at whichever
// record the suggestion is about (a Lead for LEAD_NEXT_ACTION, a
// Company for OWNER_WEEKLY_INSIGHT, etc.) — no FK so the row outlives
// the entity if it's deleted.
model AiSuggestion {
  id               String           @id @default(cuid())
  companyId        String
  company          Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type             AiSuggestionType
  entityType       String
  entityId         String
  // Markdown-ish body. Capped at ~4KB at the producer layer so a
  // runaway model response can't blow up the row.
  content          String           @db.Text
  // SHA-256 of the canonical inputs used to build the prompt. Producer
  // checks this on every call: matching hash + within the freshness
  // window ⇒ reuse the existing row instead of paying for another
  // Claude call. Recomputed when inputs change (lead stage moves,
  // new activity, etc.) so stale rows are naturally bypassed.
  // VarChar(64) signals "this is a hex digest" — any future hash change
  // (e.g. SHA-512) trips a column-length error rather than silently
  // truncating into garbage.
  inputHash        String           @db.VarChar(64)
  // Token accounting for the monthly budget check + future cost dashboard.
  // cachedTokens captures Anthropic prompt-cache hits separately so the
  // operator can see caching working.
  promptTokens     Int              @default(0)
  completionTokens Int              @default(0)
  cachedTokens     Int              @default(0)
  createdAt        DateTime         @default(now())

  // Lookup-by-entity is the hot path (lead-detail page checks for an
  // existing suggestion before calling Claude).
  @@index([companyId, type, entityType, entityId])
  // Monthly budget aggregate scans createdAt within the company.
  @@index([companyId, createdAt])
}

// Phase-9.5 risk fix — local mirror of the tenant's Meta-approved
// WhatsApp message templates. Synced from
// GET /v21.0/<whatsappBusinessAccountId>/message_templates via the
// Automated-message events that can be delivered through a Meta-approved
// template (vs. free-form text, which Meta only allows inside the 24h
// customer-service window). Keep narrow; each value is wired to a producer.
enum WaAutomationEvent {
  // Rental-contract CNIC verification link sent to landlord + renter.
  CONTRACT_VERIFY
}

// Per-company mapping of an automation event → which approved WhatsApp template
// to send for it. Without a row, the producer falls back to its prior behaviour
// (free-form text inside the 24h window, or returning a link to share manually).
// The template's body params are filled positionally by the producer; the
// expected order is documented per-event in the Settings UI.
model WhatsAppAutomation {
  id           String            @id @default(cuid())
  companyId    String
  company      Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  event        WaAutomationEvent
  // Meta template name + language (from the synced WhatsAppTemplate catalog).
  templateName String
  language     String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @default(now()) @updatedAt

  // One mapping per event per tenant; the companyId-leading unique also serves
  // tenant lookups + the cascade, so no separate @@index is needed.
  @@unique([companyId, event])
}

// ─────────────────────────────────────────────────────────── Drip sequences

enum DripStepKind {
  // Send an approved WhatsApp template to the lead's client.
  WHATSAPP_TEMPLATE
  // Create a follow-up task (CalendarEvent) for the lead's agent.
  TASK
}

enum DripEnrollmentStatus {
  ACTIVE
  COMPLETED
  // Left early — lead closed, or the client opted out / was removed.
  EXITED
}

// A reusable multi-step nurture sequence. Leads auto-enroll when they ENTER
// triggerStage (null = manual-only). Runs on the job tick (lib/drip.ts).
model DripSequence {
  id           String     @id @default(cuid())
  companyId    String
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  triggerStage LeadStage?
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now()) @updatedAt

  steps       DripStep[]
  enrollments DripEnrollment[]

  @@index([companyId])
}

model DripStep {
  id           String       @id @default(cuid())
  sequenceId   String
  sequence     DripSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  // 0-based position in the sequence.
  order        Int
  kind         DripStepKind
  // Hours to wait before running this step — measured from enrollment for the
  // first step, then from the previous step.
  delayHours   Int          @default(24)
  // WHATSAPP_TEMPLATE: the approved template name + language (body param {{1}}
  // is filled with the client's name).
  templateName String?
  templateLang String?
  // TASK: the follow-up title.
  taskTitle    String?

  @@index([sequenceId])
}

// One lead's run through one sequence. nextRunAt is when the currentStep is due.
model DripEnrollment {
  id          String               @id @default(cuid())
  companyId   String
  company     Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sequenceId  String
  sequence    DripSequence         @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  leadId      String
  lead        Lead                 @relation(fields: [leadId], references: [id], onDelete: Cascade)
  status      DripEnrollmentStatus @default(ACTIVE)
  currentStep Int                  @default(0)
  nextRunAt   DateTime
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @default(now()) @updatedAt

  // One active run per lead per sequence.
  @@unique([sequenceId, leadId])
  // Runner sweep: due ACTIVE enrollments across all tenants (like the Job queue).
  @@index([status, nextRunAt])
  // "Exit this lead's sequences" (exitLeadFromSequences / opt-out) filters by
  // leadId, and the lead-delete cascade hits it too — the [sequenceId,leadId]
  // unique is sequenceId-leading so it can't serve a leadId-only lookup.
  @@index([leadId])
}

// "Sync templates" button in Settings → Integrations; refreshed on
// demand (we don't poll, owners curate templates rarely).
//
// `status` mirrors Meta's lifecycle (APPROVED / PENDING / REJECTED /
// PAUSED / DISABLED) so the send UI can show only APPROVED entries
// while the Settings list keeps the full picture for triage.
//
// `bodyText` stores the template's body component verbatim so the
// UI can render a preview without re-fetching the catalog; the
// computed `paramCount` is the highest {{N}} placeholder in the
// body, used to size the parameter inputs.
model WhatsAppTemplate {
  id               String   @id @default(cuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Meta's template `name` is unique within a (WABA, language) pair.
  name             String
  // ISO-ish locale code Meta returns — "en", "en_US", "ur", etc.
  language         String
  // UTILITY / MARKETING / AUTHENTICATION — surface only.
  category         String
  // APPROVED / PENDING / REJECTED / PAUSED / DISABLED.
  status           String
  // Body component text with {{N}} placeholders intact.
  bodyText         String   @db.Text
  // Highest {{N}} placeholder in bodyText — 0 for templates with no
  // variables. Computed at sync time so the UI doesn't re-parse.
  paramCount       Int      @default(0)
  // Optional TEXT header — Meta also supports MEDIA headers (image/video/
  // document) which require URL uploads; those land in `headerText`
  // empty and are surfaced in the UI as "media header (not yet
  // supported by the send form)". headerParamCount mirrors paramCount
  // semantics but for the header's {{N}} placeholders.
  headerText       String?  @db.Text
  headerParamCount Int      @default(0)
  syncedAt         DateTime @default(now())

  // Send UI lists APPROVED templates per tenant.
  @@unique([companyId, name, language])
  @@index([companyId, status])
}

// Idempotency guard for financial mutations (PR4). A client generates a UUID
// per user action (e.g. "Record payment" button) and submits it; the server
// inserts the (companyId, scope, key) row first — a duplicate submit hits the
// unique constraint and replays the prior result instead of double-writing.
// Mirrors the Job (type, idempotencyKey) dedup pattern. Purged after 7 days by
// the purgeOldRows sweep.
model IdempotencyKey {
  id        String   @id @default(cuid())
  companyId String
  // Cascade so a deleted tenant's keys are cleaned up, matching every other
  // tenant-scoped model. The @@unique below leads with companyId, so the
  // cascade delete uses that index — no separate companyId index required.
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  // Operation namespace, e.g. "payment.create", "commission.approve".
  scope     String
  // Client-generated UUID, unique per user action.
  key       String
  // Id of the row the operation created, so a replay can point at the result.
  resultId  String?
  createdAt DateTime @default(now())

  @@unique([companyId, scope, key])
  // Retention sweep deletes rows older than 7 days.
  @@index([createdAt])
}

// Telemetry for public client-facing share pages (/p/[shareSlug]). One row per
// tracked view, written by the unauthenticated /api/share/track endpoint. The
// viewer's IP is never stored raw — only a salted SHA-256 digest (ipHash) so
// repeat-view detection works without holding PII. When the share link carries
// a client token, clientId links the view to a known contact, which feeds the
// lead-score "engagement" boost (lib/lead-score.ts) and the high-intent agent
// alert. clientId SetNull so a deleted client doesn't drop the historical view;
// companyId/propertyId Cascade because a view has no meaning once its tenant or
// listing is gone.
model PropertyView {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  clientId   String?
  client     Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  // Salted SHA-256 of the viewer IP — privacy-preserving, non-reversible.
  ipHash     String
  // Sanitised, length-capped User-Agent (nullable — bots/curl may omit it).
  userAgent  String?
  viewedAt   DateTime @default(now())

  // Per-client engagement. Serves both the lead-score view count
  // (scoreLeadWithViews) and the leads-list batch groupBy — both filter by
  // clientId, which already pins the tenant (a client belongs to one company).
  // Also backs the SetNull when a client is deleted (clientId-leading).
  @@index([clientId])
  // "Views by this client on this listing" — the 4-views high-intent count in
  // the track endpoint (WHERE propertyId, clientId). propertyId-leading, so it
  // also makes the cascade efficient when a property is deleted.
  @@index([propertyId, clientId])
}
