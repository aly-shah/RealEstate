# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/realestate_crm?schema=public"
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"
AUTH_TRUST_HOST="true"

# OpenAI — powers the "Write with AI" property title/description generator.
# Without it, the button shows "AI features are not configured". Get a key at
# https://platform.openai.com/api-keys. OPENAI_MODEL is optional (default gpt-4o-mini).
OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"
