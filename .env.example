# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/realestate_crm?schema=public"
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"
AUTH_TRUST_HOST="true"

# AI — powers every AI surface: "Write with AI" listing copy, lead next-action /
# reply-draft, the owner weekly insight, and the WhatsApp inbound classifier
# (which drives auto lead capture). Set EITHER provider's key and all of them
# work; with neither, AI features show "not configured" and degrade gracefully.
#
# Provider selection (lib/ai/provider.ts): AI_PROVIDER forces a provider when its
# key is set; otherwise Anthropic is preferred when present, else OpenAI.
#
# OpenAI (default model gpt-4o-mini):
OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"
# Anthropic (default model claude-opus-4-7):
ANTHROPIC_API_KEY=""
# Force a provider when both keys are set: "openai" | "anthropic" (default: auto).
# AI_PROVIDER="openai"
